# Contenus NASA facultatifs (APOD, NeoWs, DONKI). Sans clé, le quota public DEMO_KEY est utilisé.
# La clé reste strictement côté serveur.
NASA_API_KEY=

# Qualité du ciel facultative — endpoint serveur/worker renvoyant score, Bortle, SQM ou radiance.
# La clé reste strictement côté serveur. Sans URL, SkyQuest utilise une estimation prudente.
LIGHT_POLLUTION_API_URL=
LIGHT_POLLUTION_API_KEY=
LIGHT_POLLUTION_PROVIDER=

# Soutien volontaire facultatif
NEXT_PUBLIC_SUPPORT_URL=

# Supabase
# Exposables au client. La clé anon n'accorde aucun accès à push_subscriptions sans policy RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# STRICTEMENT SERVEUR : contourne la RLS. Ne jamais préfixer par NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Web Push — générer une paire avec `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# STRICTEMENT SERVEUR
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@skyquest.app

# STRICTEMENT SERVEUR : Vercel l'envoie automatiquement comme Bearer token au cron.
CRON_SECRET=

# STRICTEMENT SERVEUR : autorise /api/push/test en production avec un Bearer token.
PUSH_TEST_SECRET=
